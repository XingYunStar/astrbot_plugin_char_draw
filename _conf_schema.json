{
    "enable_log": {
        "type": "bool",
        "description": "启用日志输出",
        "default": true,
        "hint": "是否输出详细日志"
    },
    "auto_draw": {
        "type": "bool",
        "description": "自动绘画",
        "default": false,
        "hint": "是否在机器人回复后自动生成绘画"
    },
    "use_simple_prompt": {
        "type": "bool",
        "description": "简化提示词模式",
        "default": false,
        "hint": "使用简化的提示词模板"
    },
    "llm_api_url": {
        "type": "string",
        "description": "LLM API地址",
        "default": "https://api.siliconflow.cn/v1/chat/completions",
        "hint": "用于优化绘画提示词的 LLM API 地址"
    },
    "llm_api_key": {
        "type": "string",
        "description": "LLM API Key",
        "default": "",
        "hint": "你的 LLM API Key（必需）"
    },
    "llm_model": {
        "type": "string",
        "description": "LLM 模型",
        "default": "deepseek-ai/DeepSeek-V3.2",
        "hint": "使用的模型名称"
    },
    "draw_api_url": {
        "type": "string",
        "description": "绘画API地址",
        "default": "",
        "hint": "Stable Diffusion API 地址（必需）"
    },
    "draw_steps": {
        "type": "int",
        "description": "绘画步数",
        "default": 42,
        "minimum": 20,
        "maximum": 50,
        "hint": "生成图片的迭代步数"
    },
    "draw_cfg_scale": {
        "type": "int",
        "description": "提示词相关性",
        "default": 8,
        "minimum": 1,
        "maximum": 15,
        "hint": "提示词对生成结果的影响程度"
    },
    "draw_sampler": {
        "type": "string",
        "description": "采样器",
        "default": "DPM++ SDE Karras",
        "hint": "绘画使用的采样算法"
    },
    "negative_prompt": {
        "type": "text",
        "description": "负面提示词",
        "default": "",
        "hint": "不希望出现在图片中的内容"
    },
    "draw_system_prompt": {
        "type": "text",
        "description": "绘画提示词系统提示",
        "default": "",
        "hint": "自定义完整模式下的系统提示词"
    },
    "simple_system_prompt": {
        "type": "text",
        "description": "简化模式系统提示",
        "default": "",
        "hint": "自定义简化模式下的系统提示词"
    }
}
